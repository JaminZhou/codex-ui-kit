    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "42.3.0",
    "electron-vite": "5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
