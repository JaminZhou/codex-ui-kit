{
  "name": "codex-ui-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Independently designed React components for Codex-style coding-agent interfaces.",
  "keywords": [
    "agent-ui",
    "codex",
    "react",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaminZhou/codex-ui-kit.git"
  },
  "homepage": "https://jaminzhou.com/codex-ui-kit/",
  "bugs": {
    "url": "https://github.com/JaminZhou/codex-ui-kit/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": {
      "types": "./dist/styles.d.ts",
      "default": "./dist/style.css"
    },
    "./tokens.css": {
      "types": "./dist/tokens.d.ts",
      "default": "./dist/tokens.css"
    }
  },
  "scripts": {
    "dev": "vite demo --config demo/vite.config.ts",
    "dev:electron": "pnpm build && pnpm --filter @codex-ui-kit/electron-playground dev",
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:demo": "vite build demo --base=/codex-ui-kit/ --config demo/vite.config.ts && node scripts/check-demo-bundle.mjs",
    "build:electron": "pnpm --filter @codex-ui-kit/electron-playground build",
    "prepack": "node scripts/prepack.mjs",
    "test": "vitest run tests",
    "typecheck": "tsc --noEmit",
    "check:package": "node scripts/check-package.mjs && tsc -p fixtures/package-consumer/tsconfig.json",
    "check": "pnpm typecheck && pnpm test && pnpm build && pnpm check:package && pnpm build:demo && pnpm --filter @codex-ui-kit/electron-playground check"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "highlight.js": "11.11.1",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1"
  }
}
